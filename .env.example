# Environment Variable Reference
# Copy this file to `.env` and fill in the required values.

# ─────────────────────────────────────────────
# Slack Bot
# ─────────────────────────────────────────────

# OAuth Bot Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Signing secret from your Slack App settings
SLACK_SIGNING_SECRET=your-signing-secret-here

# ─────────────────────────────────────────────
# OpenAI (XAI Agent)
# ─────────────────────────────────────────────

# Your OpenAI API key. Set to "dummy" to run in mock mode.
OPENAI_API_KEY=sk-your-openai-key-here

# ─────────────────────────────────────────────
# Service URLs (used by the bot)
# ─────────────────────────────────────────────

# When running locally outside Docker Compose, point to localhost
ORCHESTRATOR_URL=http://orchestrator:8080
AGENT_URL=http://agent:8000

# ─────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────

# Application version injected into service health responses
APP_VERSION=dev

# Log level for the bot (info | debug)
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins for the agent
# CORS_ORIGINS=https://yourdomain.com
